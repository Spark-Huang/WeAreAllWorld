{
  "name": "weareallworld",
  "version": "1.0.0",
  "description": "大同世界 - AI nurturing + text adventure + practical assistant platform",
  "license": "BSL-1.1",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node -r dotenv/config dist/index.js",
    "dev:api": "API_PORT=3000 ts-node-dev --respawn src/index.ts",
    "dev:frontend": "cd src_frontend && pnpm dev",
    "dev:admin": "cd src_admin/admin && pnpm dev",
    "dev:web-admin": "cd src_admin/web && pnpm dev",
    "dev:all": "concurrently \"pnpm dev\" \"pnpm dev:frontend\"",
    "dev:full": "concurrently \"pnpm dev:api\" \"pnpm dev:frontend\" \"pnpm dev:admin\"",
    "build:admin": "cd src_admin/admin && pnpm build",
    "build:web-admin": "cd src_admin/web && pnpm build",
    "test": "pnpm test:unit",
    "test:unit": "npx ts-node tests/regression/unit/unit-test.ts",
    "test:e2e": "npx ts-node tests/regression/e2e/e2e-test.ts",
    "test:security": "npx ts-node tests/regression/security/security-test.ts",
    "test:all": "npx ts-node tests/run-all-tests.ts",
    "lint": "eslint src/**/*.ts",
    "test:regression": "pnpm test:all"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "@types/ws": "^8.18.1",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "i18next": "^25.8.17",
    "i18next-browser-languagedetector": "^8.2.1",
    "node-cron": "^3.0.3",
    "react-i18next": "^16.5.6",
    "telegraf": "^4.16.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "chatbot",
    "telegram",
    "game",
    "nurturing"
  ],
  "author": "Spark-Huang",
  "license": "MIT"
}